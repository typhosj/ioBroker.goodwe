{
  "name": "iobroker.goodwe",
  "version": "1.1.1",
  "description": "Communication with GoodWe Inverter ET/EH/BH/BT Series",
  "author": {
    "name": "Thomas Schönberger",
    "email": "SchoenbergerThomas@freenet.de"
  },
  "contributors": [
    {
      "name": "typhosj",
      "email": "typhosj@gmx.de"
    }
  ],
  "homepage": "https://github.com/typhosj/ioBroker.goodwe",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "GoodWe",
    "Inverter",
    "ET",
    "EH",
    "BH",
    "BT"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/typhosj/ioBroker.goodwe.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^8.2.13",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.2.2",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.13.14",
    "@types/proxyquire": "^1.3.31",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "proxyquire": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  },
  "overrides": {
    "brace-expansion": "^1.1.15",
    "diff": "^9.0.0",
    "esbuild": "^0.25.12",
    "serialize-javascript": "^7.0.6"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:admin",
    "build:admin": "vite build --config vite.admin.config.mjs",
    "build:ts": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test:js": "npm run build:test && mocha --config test/mocharc.custom.json \"build-test/test/main.test.js\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes"
  },
  "bugs": {
    "url": "https://github.com/typhosj/ioBroker.goodwe/issues"
  },
  "readmeFilename": "README.md"
}
